# Runtime profile.
SBK_ENV=production
SBK_BACKEND_PORT=8080
SBK_PUBLIC_BASE_URL=https://billing.example.com
SBK_REQUIRE_HTTPS=true

# Google Play product identifiers.
SBK_PACKAGE_NAME=com.shortsblockerkids
SBK_PLAY_SUBSCRIPTION_PRODUCT_ID=shorts_blocker_kids_monthly

# PostgreSQL runtime storage. Set real user/password only in the deployment env.
SBK_DATABASE_NAME=shorts_blocker_kids
SBK_DATABASE_USER=
SBK_DATABASE_PASSWORD=
SBK_DATABASE_URL=jdbc:postgresql://billing-db:5432/shorts_blocker_kids
SBK_RUN_MIGRATIONS=true
SBK_MIGRATIONS_DIR=/opt/shorts-blocker-kids/billing-backend/migrations

# Authenticated Pub/Sub push config for RTDN.
SBK_RTDN_PUBSUB_AUDIENCE=https://billing.example.com/billing/play/rtdn
SBK_RTDN_PUBSUB_SERVICE_ACCOUNT_EMAIL=

# Request limits.
SBK_MAX_REQUEST_BYTES=32768
SBK_RATE_LIMIT_VERIFY_PER_MINUTE=30
SBK_RATE_LIMIT_STATUS_PER_MINUTE=120
SBK_RATE_LIMIT_RTDN_PER_MINUTE=300

# Docker image tag used by deploy/rollback scripts.
SBK_BACKEND_IMAGE=shorts-blocker-kids-billing-backend:local

# Host path used by Docker Compose secret mounting.
# Do not commit the referenced JSON file.
SBK_GOOGLE_APPLICATION_CREDENTIALS_HOST=/secure/path/service-account.json
