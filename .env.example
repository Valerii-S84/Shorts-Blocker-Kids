SBK_BACKEND_PORT=8080
SBK_PACKAGE_NAME=com.shortsblockerkids
SBK_PLAY_SUBSCRIPTION_PRODUCT_ID=shorts_blocker_kids_monthly
SBK_BACKEND_STORE_FILE=/data/entitlements/billing-backend-data.json
SBK_RTDN_SHARED_SECRET=replace-with-runtime-secret
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/google-service-account.json

# Host path used only when mounting a local service-account file into Docker.
# Do not commit the referenced JSON file.
SBK_GOOGLE_APPLICATION_CREDENTIALS_HOST=/secure/path/service-account.json
